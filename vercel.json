{
    "builds": [
      {
        "src": "manage.py",
        "use": "@vercel/python",
        "config": { "maxLambdaSize": "50mb" }
      }
    ],
    "routes": [
      { "src": "/static/(.*)", "dest": "/static/$1" },
      { "src": "/(.*)", "dest": "manage.py" }
    ],
    "env": {
      "DJANGO_SETTINGS_MODULE": "dropagent.settings",
      "SECRET_KEY": "@SECRET_KEY",
      "EMAIL_HOST_PASSWORD": "@EMAIL_HOST_PASSWORD"
    }
  }
  